{
  "MSTest Test Class": {
    "prefix": "tc",
    "body": [
      "[TestClass]",
      "public sealed class ${1:ClassName}Test",
      "{",
      "\t$0",
      "}"
    ],
    "description": "create mstest test class"
  },
  "MSTest Test Method": {
    "prefix": "tm",
    "body": [
      "[TestMethod]",
      "public void ${1:TestName}()",
      "{",
      "\t$0",
      "}"
    ],
    "description": "create mstest test method"
  },
  "MSTest Test Method Async": {
    "prefix": "tm",
    "body": [
      "[TestMethod]",
      "public async Task ${1:TestName}()",
      "{",
      "\t$0",
      "}"
    ],
    "description": "create async mstest test method"
  }
}
